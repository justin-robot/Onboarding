    "@repo/next-config": "workspace:*",
    "@repo/notifications": "workspace:*",
    "@repo/observability": "workspace:*",
    "@repo/realtime": "workspace:*",
    "@repo/seo": "workspace:*",
    "@repo/storage": "workspace:*",
    "@signnow/api-client": "^3.1.0",
    "@tremor/react": "^3.18.7",
    "ably": "^2.4.2",
    "date-fns": "^4.1.0",
    "fuse.js": "^7.1.0",
    "googleapis": "^171.4.0",
    "import-in-the-middle": "^2.0.0",
    "keyv": "^5.6.0",
    "kysely": "^0.28",
    "lucide-react": "^0.556.0",
    "next": "16.0.10",
    "next-themes": "^0.4.6",
    "ra-core": "^5.13.4",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-hook-form": "^7.68.0",
    "require-in-the-middle": "8.0.1",
    "sharp": "^0.34.5",
