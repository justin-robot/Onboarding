# ============================================
# CORE
# ============================================
ANALYZE=
NEXT_RUNTIME=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WEB_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3002

# Database

# Development database (used for migrations: pnpm run migrate:dev)
DATABASE_URL_DEV=
DATABASE_URL_DEV_ADMIN=

# Production database (used for migrations: pnpm run migrate:prod)
DATABASE_URL_PROD=
DATABASE_URL_PROD_ADMIN=

# Authentication (Better Auth)
# Generate with npx @better-auth/cli secret
BETTER_AUTH_SECRET=

# Email (Resend)
RESEND_TOKEN=
RESEND_FROM=


# Analytics (Posthog)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ============================================
# ADDITIONAL SERVICES
# ============================================

# Payments (Polar)
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_SERVER=

# Webhooks (Svix)
SVIX_TOKEN=

# Real-time (Ably)
ABLY_API_KEY=

# Notifications (Knock)
KNOCK_SECRET_API_KEY=
NEXT_PUBLIC_KNOCK_API_KEY=
NEXT_PUBLIC_KNOCK_FEED_CHANNEL_ID=

# Internationalization (Languine)
LANGUINE_PROJECT_ID=

# AI (OpenAI)
OPENAI_API_KEY=

# E-Signing (SignNow)
# Create an account at https://www.signnow.com/developers
# For sandbox, use api-eval.signnow.com; for production, use api.signnow.com
SIGNNOW_CLIENT_CREDENTIALS=  # Base64 encoded client_id:client_secret
SIGNNOW_USERNAME=            # SignNow account email
SIGNNOW_PASSWORD=            # SignNow account password
SIGNNOW_SENDER_EMAIL=        # Email address shown as sender (optional)
SIGNNOW_WEBHOOK_SECRET=      # Webhook signature verification (optional)