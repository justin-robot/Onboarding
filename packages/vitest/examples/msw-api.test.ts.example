/**
 * Example: Testing with MSW (Mock Service Worker)
 * 
 * MSW intercepts network requests and returns mocked responses.
 * Perfect for testing API integrations without hitting real endpoints.
 */

import { describe, it, expect } from "vitest";
import { http, HttpResponse, server } from "@repo/vitest";

describe("API with MSW", () => {
  it("should mock API responses globally", async () => {
    // This uses handlers defined in msw/handlers.ts
    const response = await fetch("https://api.example.com/user");
    const data = await response.json();

    expect(response.ok).toBe(true);
    expect(data).toBeDefined();
  });

  it("should override handlers for specific tests", async () => {
    // Override handler just for this test
    server.use(
      http.get("https://api.example.com/products", () => {
        return HttpResponse.json([
          { id: 1, name: "Product 1" },
          { id: 2, name: "Product 2" },
        ]);
      })
    );

    const response = await fetch("https://api.example.com/products");
    const products = await response.json();

    expect(products).toHaveLength(2);
    expect(products[0].name).toBe("Product 1");
  });

  it("should mock error responses", async () => {
    server.use(
      http.get("https://api.example.com/error", () => {
        return new HttpResponse(null, {
          status: 500,
          statusText: "Internal Server Error",
        });
      })
    );

    const response = await fetch("https://api.example.com/error");
    expect(response.ok).toBe(false);
    expect(response.status).toBe(500);
  });

  it("should mock POST requests", async () => {
    server.use(
      http.post("https://api.example.com/users", async ({ request }) => {
        const body = await request.json();
        
        return HttpResponse.json({
          id: "new-id",
          ...body,
        }, { status: 201 });
      })
    );

    const response = await fetch("https://api.example.com/users", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ name: "John Doe", email: "john@example.com" }),
    });

    const data = await response.json();
    expect(response.status).toBe(201);
    expect(data.id).toBe("new-id");
    expect(data.name).toBe("John Doe");
  });
});

